{
  "name": "gundb-wormhole",
  "version": "1.1.0",
  "description": "P2P file transfer tool using GunDB and a CLI.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "gwh": "src/index.js"
  },
  "scripts": {
    "build": "cd web && yarn install && yarn build && cd .. && rm -rf dist && cp -r web/dist dist",
    "dev": "cd web && yarn dev",
    "start": "npx serve dist",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "gundb",
    "p2p",
    "file-transfer",
    "cli",
    "wormhole"
  ],
  "author": "Shogun",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "clipboardy": "^4.0.0",
    "dotenv": "^17.2.3",
    "filesize": "^10.1.0",
    "gun": "https://github.com/scobru/gun",
    "ora": "^8.0.1",
    "shogun-relays": "https://github.com/scobru/shogun-relays",
    "vercel": "^50.22.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "serve": "^14.2.1"
  }
}
